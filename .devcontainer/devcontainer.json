{
  "name": "Node.js Backend Codespace",
  // Automatically forwards port 3000 when the application starts running
  "forwardPorts": [3000],
  
  // Changes the visibility of port 3000 to public automatically
  "portsAttributes": {
    "3000": {
      "label": "Backend Dev Server",
      "onMoforward": "notify",
      "visibility": "public"
    }
  },

  // Runs your commands every single time the codespace is switched ON/started
  "postStartCommand": "cd backend && npm install && npm run start:dev"
}