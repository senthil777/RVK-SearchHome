{
  "name": "Node.js Backend Codespace",
  "forwardPorts": [3000],
  
  "portsAttributes": {
    "3000": {
      "label": "Backend Dev Server",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },

  // 1. Installs your modules once during a build
  "updateContentCommand": "cd backend && npm install",

  // 2. The crucial fix: Added " &" at the end so it doesn't freeze the boot process
  "postStartCommand": "cd backend && npm run start:dev &"
}