{
  "name": "RVK Backend",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "cd backend && npm install",
  "postStartCommand": "cd backend && npx prisma db push",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "NestJS API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  }
}