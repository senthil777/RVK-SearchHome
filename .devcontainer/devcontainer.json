{
  "name": "Node.js Backend Codespace",
  // Automatically forwards port 3000 when the application starts running
  "forwardPorts": [3000],
  
  // Changes the visibility of port 3000 to public automatically
  "portsAttributes": {
    "3000": {
      "label": "Backend Dev Server",
      "onMoforward": "notify",
      "visibility": "public"
    }
  },

"updateContentCommand": "cd backend && npm install",

  // 2. Daily routine happens instantly (When you use your HTML switch)
  "postStartCommand": "cd backend && npm run start:dev"
}